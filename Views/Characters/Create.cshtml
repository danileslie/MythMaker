@model MythMaker.Models.CreateCharacterViewModel

<h2>Create Character</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Race"></label>
        <select id="raceSelect" class="form-control" aria-label="Race preset">
            <option value="Human">Human</option>
            <option value="Elf">Elf</option>
            <option value="Dwarf">Dwarf</option>
            <option value="Halfling">Halfling</option>
            <option value="Other">Other</option>
        </select>
        <input asp-for="Race" id="raceInput" class="form-control mt-2" style="display:none;" placeholder="Enter custom race" />
    </div>

    <div class="form-group">
        <label asp-for="Class"></label>
        <select id="classSelect" class="form-control" aria-label="Class preset">
            <option value="Fighter">Fighter</option>
            <option value="Wizard">Wizard</option>
            <option value="Rogue">Rogue</option>
            <option value="Cleric">Cleric</option>
            <option value="Other">Other</option>
        </select>
        <input asp-for="Class" id="classInput" class="form-control mt-2" style="display:none;" placeholder="Enter custom class" />
    </div>

    <div class="form-group">
        <label asp-for="Level"></label>
        <input asp-for="Level" class="form-control" />
        <span asp-validation-for="Level" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Strength"></label>
        <input asp-for="Strength" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Dexterity"></label>
        <input asp-for="Dexterity" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Constitution"></label>
        <input asp-for="Constitution" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Intelligence"></label>
        <input asp-for="Intelligence" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Wisdom"></label>
        <input asp-for="Wisdom" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Charisma"></label>
        <input asp-for="Charisma" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Backstory"></label>
        <textarea asp-for="Backstory" class="form-control" rows="6"></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Create Character</button>
</form>

@section Scripts {
    <script>
        function setupDropdown(selectId, inputId) {
            const select = document.getElementById(selectId);
            const input = document.getElementById(inputId);

            select.addEventListener('change', function () {
                if (select.value === 'Other') {
                    input.style.display = 'block';
                    input.value = '';
                } else {
                    input.style.display = 'none';
                    input.value = select.value;
                }
            });

            input.value = select.value;
        }

        setupDropdown('raceSelect', 'raceInput');
        setupDropdown('classSelect', 'classInput');
    </script>
}
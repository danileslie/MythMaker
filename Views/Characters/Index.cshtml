@model MythMaker.Models.CharacterIndexViewModel

<h2>My Characters</h2>

<a asp-action="Create" class="btn btn-success mb-3">Create New Character</a>

@if (!Model.FinalizedCharacters.Any())
{
    <p>You haven't created any characters yet. <a asp-action="Create">Create your first one</a>.</p>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
        @foreach (var character in Model.FinalizedCharacters)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@character.Name</h5>
                        <p class="card-text">@character.Race @character.Class</p>
                        <p class="card-text"><small class="text-muted">Level @character.Level</small></p>
                        <a asp-action="Details" asp-route-id="@character.Id" class="btn btn-primary">View</a>
                        
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (Model.Drafts.Any())
{
    <h3 class="mt-4">Drafts</h3>
    <ul>
        @foreach (var draft in Model.Drafts)
        {
            <li>
                @(string.IsNullOrEmpty(draft.Name) ? "(unnamed draft)" : draft.Name)
                <a asp-action="Create" asp-route-id="@draft.Id">Resume</a>
                <a asp-action="Delete" asp-route-id="@draft.Id">Delete</a>
            </li>
        }
    </ul>
}